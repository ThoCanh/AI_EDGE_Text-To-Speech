## 💻 PHẦN 5: PSEUDO-CODE (Python)

```python
import numpy as np
import sounddevice as sd
import threading
import subprocess
import struct
import gc
import os

# ═══════════════════════════════════════════════
# VOICE-TO-VOICE PIPELINE - PUSH TO TALK
# Target: Raspberry Pi 5 (Cortex-A76, 4GB RAM)
# ASR: whisper.cpp (Q5_0 GGUF) 
# TTS: Piper TTS (Vietnamese)
# ═══════════════════════════════════════════════

class VoicePipeline:
    """
    Singleton Voice Pipeline - tất cả model được load 1 lần duy nhất.
    Audio data truyền qua RAM buffer, không ghi file trung gian.
    """

    SAMPLE_RATE = 16000       # Whisper yêu cầu 16kHz
    CHANNELS = 1              # Mono
    DTYPE = np.float32        # PCM format cho whisper.cpp
    NUM_THREADS = 2           # Optimal cho Pi5 (xem giải trình)

    def __init__(self, asr_model_path: str, tts_model_path: str):
        """
        WARM-UP PHASE: Load model vào RAM đúng 1 lần.
        Được gọi khi chương trình khởi động (boot).
        """
        # ---- Load ASR Model (whisper.cpp) ----
        # Sử dụng C binding qua ctypes hoặc whispercpp Python package
        from whispercpp import Whisper
        self._asr = Whisper.from_pretrained(
            asr_model_path,             # "models/ggml-tiny-q5_0.bin"
            n_threads=self.NUM_THREADS,  # 2 threads tối ưu
        )
        
        # ---- Load TTS Model (Piper - subprocess persistent) ----
        # Piper chạy như 1 long-lived subprocess, model load 1 lần
        self._tts_process = subprocess.Popen(
            [
                "./piper/piper",
                "--model", tts_model_path,   # "vi_VN-vais1000-medium.onnx"
                "--output-raw",               # Output raw PCM, không WAV header
                "--length-scale", "0.9",      # Tăng tốc độ đọc nhẹ
            ],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
        )

        # ---- Audio I/O ----
        self._audio_buffer = bytearray()      # Buffer ghi âm trong RAM
        self._is_recording = False
        self._lock = threading.Lock()
        
        # ---- Pre-warm inference (chạy 1 lần dummy để JIT optimize) ----
        dummy_audio = np.zeros(self.SAMPLE_RATE, dtype=self.DTYPE)
        self._asr.transcribe(dummy_audio)  # Warm-up ASR cache
        
        print("[BOOT] ✅ Pipeline warm-up hoàn tất. Sẵn sàng nhận lệnh.")

    # ─────────────────────────────────────────────
    # PUSH-TO-TALK: Event Handlers
    # ─────────────────────────────────────────────

    def on_button_press(self):
        """
        Sự kiện: Người dùng BẤM nút (Push).
        Bắt đầu ghi âm PCM vào RAM buffer.
        """
        with self._lock:
            self._audio_buffer = bytearray()    # Reset buffer
            self._is_recording = True

        # Mở audio stream - callback ghi trực tiếp vào buffer
        self._stream = sd.InputStream(
            samplerate=self.SAMPLE_RATE,
            channels=self.CHANNELS,
            dtype='float32',
            blocksize=1024,
            callback=self._audio_callback,
        )
        self._stream.start()
        print("[REC] 🎤 Đang ghi âm...")

    def _audio_callback(self, indata: np.ndarray, frames, time_info, status):
        """
        Callback: Ghi PCM data trực tiếp vào RAM buffer.
        Không ghi file, không dùng temp.wav.
        """
        if self._is_recording:
            # Chuyển numpy array → bytes và append vào buffer
            self._audio_buffer.extend(indata.tobytes())

    def on_button_release(self):
        """
        Sự kiện: Người dùng NHẢ nút (Release).
        Dừng ghi → ASR → TTS → Phát loa.
        """
        # 1. Dừng ghi âm
        with self._lock:
            self._is_recording = False
        self._stream.stop()
        self._stream.close()
        print("[REC] ⏹️ Dừng ghi âm.")

        # 2. Chuyển buffer → numpy array (trong RAM, không qua file)
        pcm_array = np.frombuffer(
            bytes(self._audio_buffer), dtype=np.float32
        )
        
        # 3. ASR Inference: PCM bytes → Text
        text = self._run_asr(pcm_array)
        print(f"[ASR] 📝 Nhận dạng: '{text}'")

        # 4. TTS Inference: Text → PCM Audio bytes
        tts_audio = self._run_tts(text)
        print(f"[TTS] 🔊 Đã tổng hợp {len(tts_audio)} samples")

        # 5. Phát âm thanh ra loa
        self._play_audio(tts_audio)

        # 6. Giải phóng buffer trung gian → tránh memory leak
        del pcm_array, tts_audio
        self._audio_buffer = bytearray()
        gc.collect()

    # ─────────────────────────────────────────────
    # INFERENCE ENGINES
    # ─────────────────────────────────────────────

    def _run_asr(self, pcm_data: np.ndarray) -> str:
        """
        Whisper-Tiny ASR: numpy array (float32, 16kHz) → text.
        Model đã được load sẵn trong RAM từ __init__().
        Dữ liệu truyền trực tiếp qua RAM pointer, không I/O.
        """
        result = self._asr.transcribe(pcm_data)
        return result.strip()

    def _run_tts(self, text: str) -> np.ndarray:
        """
        Piper TTS: text → raw PCM audio (int16, 22050Hz).
        Giao tiếp qua stdin/stdout pipe (trong RAM).
        """
        # Gửi text qua stdin pipe
        self._tts_process.stdin.write(f"{text}\n".encode("utf-8"))
        self._tts_process.stdin.flush()

        # Đọc raw PCM output từ stdout pipe
        # Piper output: int16, 22050Hz, mono
        raw_bytes = self._tts_process.stdout.read()
        audio = np.frombuffer(raw_bytes, dtype=np.int16)
        return audio.astype(np.float32) / 32768.0  # Normalize

    def _play_audio(self, audio: np.ndarray):
        """Phát audio qua loa - blocking."""
        sd.play(audio, samplerate=22050)
        sd.wait()

    # ─────────────────────────────────────────────
    # CLEANUP
    # ─────────────────────────────────────────────

    def shutdown(self):
        """Giải phóng tài nguyên khi tắt chương trình."""
        self._tts_process.terminate()
        self._tts_process.wait()
        del self._asr
        gc.collect()
        print("[SHUTDOWN] 🔴 Pipeline đã tắt.")


# ═══════════════════════════════════════════════
# MAIN - Entry Point
# ═══════════════════════════════════════════════

if __name__ == "__main__":
    # Khởi tạo pipeline (load model 1 lần)
    pipeline = VoicePipeline(
        asr_model_path="models/ggml-tiny-q5_0.bin",
        tts_model_path="models/vi_VN-vais1000-medium.onnx",
    )

    # Giả lập GPIO button hoặc keyboard event
    try:
        while True:
            input(">>> Nhấn ENTER để bắt đầu ghi âm...")
            pipeline.on_button_press()
            input(">>> Nhấn ENTER để dừng và xử lý...")
            pipeline.on_button_release()
    except KeyboardInterrupt:
        pipeline.shutdown()
```

